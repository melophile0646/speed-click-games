{
  "name": "speed-click-game",
  "version": "1.0.0",
  "description": "Professional onchain Speed Click game on Story Protocol with Web3 wallet integration and leaderboard",
  "type": "module",
  "main": "index.jsx",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:vercel": "vercel",
    "deploy:netlify": "netlify deploy --prod",
    "hardhat:compile": "hardhat compile",
    "hardhat:deploy:testnet": "hardhat run scripts/deploy.js --network storyTestnet",
    "hardhat:deploy:mainnet": "hardhat run scripts/deploy.js --network storyMainnet",
    "hardhat:test": "hardhat test",
    "hardhat:verify": "hardhat verify",
    "lint": "eslint src --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ethers": "^6.7.1",
    "web3modal": "^3.0.0",
    "@web3modal/ethers": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^4.3.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "hardhat": "^2.17.0",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.0",
    "@nomiclabs/hardhat-ethers": "^10.0.0",
    "@nomiclabs/hardhat-etherscan": "^3.1.0",
    "dotenv": "^16.0.0",
    "eslint": "^8.40.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "keywords": [
    "web3",
    "blockchain",
    "story-protocol",
    "game",
    "solidity",
    "react",
    "ethers.js",
    "leaderboard",
    "smart-contract"
  ],
  "author": "Speed Click Game Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/speed-click-game.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/speed-click-game/issues"
  },
  "homepage": "https://github.com/your-username/speed-click-game#readme"
}
